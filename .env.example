# AgriTrack Environment Configuration
# Copy this to .env and fill in your values

# ===================
# DATABASE (Turso/PostgreSQL)
# ===================
DATABASE_URL=libsql://agritacker-sarahman.aws-ap-south-1.turso.io
DATABASE_AUTH_TOKEN=YOUR_TURSO_AUTH_TOKEN_HERE

# ===================
# AUTHENTICATION
# ===================
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=24h
OTP_SECRET=your-otp-secret-key

# ===================
# SMS & NOTIFICATIONS
# ===================
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890
MSG91_API_KEY=your-msg91-api-key

# ===================
# STORAGE (AWS S3/Azure)
# ===================
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=agritrack-media

# ===================
# FIREBASE (Push Notifications)
# ===================
FCM_SERVER_KEY=your-firebase-server-key
FCM_PROJECT_ID=agritrack-app

# ===================
# EXTERNAL APIs
# ===================
ELASTICSEARCH_URL=http://localhost:9200
REDIS_URL=redis://localhost:6379

# ===================
# APP CONFIG
# ===================
NODE_ENV=development
PORT=3000
API_VERSION=v1

# ===================
# INTEGRATION (Future)
# ===================
AGRIPULSE_API_URL=https://api.agripulse.in
DigiAcre_API_URL=https://api.digiacre.in
KHTI_API_URL=https://api.kheti.in